<section id="details-page">

    <div class="main_card">
        <div class="card_left">
            <div class="card_datails">

                <h1>{{movie.title}}</h1>
                <div class="card-movie">
                    <div class="first-info">
                        <p class="card-genre">Genre: {{movie.genre}}</p>
                        <p class="card-director">Director: {{movie.director}}</p>

                    </div>
                    <div class="second-info">

                        <p class="card-year">Year: {{movie.year}}</p>
                        <p class="card-ranking">Rating:
                            <span id="stars">
                                {{{stars}}}
                            </span>
                        </p>
                    </div>

                </div>

                <p class="disc">Description: {{movie.description}}</p>
                <p class="card-category">Category: {{movie.category}}</p>
            </div>

            <div>
                <a href="/movies/{{movie.id}}/attach" class="details">Attach</a>
                <a href="/movies/{{movie.id}}/edit" class="details">Edit</a>
                <a href="/movies/{{movie.id}}/delete" class="details">Delete</a>
            </div>

        </div>
        <div class="card_right">
            <img src={{movie.imageUrl}} alt="image">
        </div>
    </div>

    <div class="main-cast-card">

        {{#each movie.artists as |artist|}}

        <div class="cast-card">
            <div class="card-img">
                 <img src="{{artist.imageUrl}}" alt="{{artist.name}}">
            </div>
            <div class="cast-info">
                <h1>{{artist.name}}</h1>
                <h3>Age: {{artist.age}}</h3>
                <h3>Born: {{artist.born}}</h3>
                {{!-- <h3>Name in Movie: Ariel</h3> --}}
            </div>
        </div>

        {{/each}}
    </div>

</section>